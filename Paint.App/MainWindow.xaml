<Window x:Class="Paint.App.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:Paint.App"
        mc:Ignorable="d"
        Title="MainWindow" Height="450" Width="800"
        Loaded="Window_Loaded" >
    <DockPanel>
        
        <StackPanel x:Name="PluginsPanel" 
                DockPanel.Dock="Top" 
                Orientation="Horizontal" 
                Background="#EEE" 
                Height="50">
            <TextBlock Text="Выбери фигуру:" VerticalAlignment="Center" Margin="10,0"/>
        </StackPanel>
        
        <StackPanel Orientation="Horizontal" DockPanel.Dock="Top" Background="#DDD">
            <Button Content="Сохранить проект" Click="SaveProject_Click" Margin="5" Padding="10,2"/>
            <Button Content="Открыть проект" Click="LoadProject_Click" Margin="5" Padding="10,2"/>
            <Button Content="📁 Загрузить плагин" 
            Click="LoadPluginFromFile_Click" 
            Margin="10,5" 
            Padding="10,0" 
            Background="#FFD700" 
            FontWeight="Bold"/>
        </StackPanel>
      
        
        <StackPanel DockPanel.Dock="Left" Width="150" Background="#F5F5F5" >
            <TextBlock Text="Цвет обводки:" Margin="0,5,0,2"/>
            <ComboBox x:Name="StrokeColorPicker" SelectedIndex="0" SelectionChanged="StrokeColorPicker_SelectionChanged" >
                <ComboBoxItem Content="Черный" Tag="{x:Static Brushes.Black}"/>
                <ComboBoxItem Content="Серый" Tag="{x:Static Brushes.Gray}"/>
                <ComboBoxItem Content="Белый" Tag="{x:Static Brushes.White}"/>
                <ComboBoxItem Content="Красный" Tag="{x:Static Brushes.Red}"/>
                <ComboBoxItem Content="Оранжевый" Tag="{x:Static Brushes.Orange}"/>
                <ComboBoxItem Content="Желтый" Tag="{x:Static Brushes.Yellow}"/>
                <ComboBoxItem Content="Зеленый" Tag="{x:Static Brushes.Green}"/>
                <ComboBoxItem Content="Голубой" Tag="{x:Static Brushes.Cyan}"/>
                <ComboBoxItem Content="Синий" Tag="{x:Static Brushes.Blue}"/>
                <ComboBoxItem Content="Фиолетовый" Tag="{x:Static Brushes.Purple}"/>
                <ComboBoxItem Content="Розовый" Tag="{x:Static Brushes.Pink}"/>
                <ComboBoxItem Content="Коричневый" Tag="{x:Static Brushes.Brown}"/>
                <ComboBoxItem Content="Без обводки" Tag="{x:Static Brushes.Transparent}"/>
            </ComboBox>

            <TextBlock Text="Заливка:" Margin="0,10,0,2"/>
            <ComboBox x:Name="FillColorPicker" SelectedIndex="0" SelectionChanged="FillColorPicker_SelectionChanged" >
                <ComboBoxItem Content="Прозрачный" Tag="{x:Static Brushes.Transparent}"/>
                <ComboBoxItem Content="Белый" Tag="{x:Static Brushes.White}"/>
                <ComboBoxItem Content="Серый" Tag="{x:Static Brushes.LightGray}"/>
                <ComboBoxItem Content="Черный" Tag="{x:Static Brushes.Black}"/>
                <ComboBoxItem Content="Красный" Tag="{x:Static Brushes.Red}"/>
                <ComboBoxItem Content="Оранжевый" Tag="{x:Static Brushes.Orange}"/>
                <ComboBoxItem Content="Желтый" Tag="{x:Static Brushes.Yellow}"/>
                <ComboBoxItem Content="Зеленый" Tag="{x:Static Brushes.Green}"/>
                <ComboBoxItem Content="Голубой" Tag="{x:Static Brushes.LightBlue}"/>
                <ComboBoxItem Content="Синий" Tag="{x:Static Brushes.Blue}"/>
                <ComboBoxItem Content="Фиолетовый" Tag="{x:Static Brushes.BlueViolet}"/>
                <ComboBoxItem Content="Розовый" Tag="{x:Static Brushes.HotPink}"/>
                <ComboBoxItem Content="Коричневый" Tag="{x:Static Brushes.SandyBrown}"/>
            </ComboBox>

            <TextBlock Text="Толщина:" Margin="0,10,0,2"/>
            <Slider x:Name="ThicknessSlider" Minimum="1" Maximum="20" Value="1" ValueChanged="ThicknessSlider_ValueChanged" PreviewMouseLeftButtonDown="ThicknessSlider_Start" 
        PreviewMouseLeftButtonUp="ThicknessSlider_End"/>
            <TextBlock Text="{Binding ElementName=ThicknessSlider, Path=Value, StringFormat={}{0:F0}}" HorizontalAlignment="Center" FontWeight="Bold"/>

            <Button Content="Курсор (Выбор)" Click="SelectMode_Click" Margin="0,20,0,5" Padding="5"/>
        </StackPanel>

       
        <StackPanel DockPanel.Dock="Right" Width="180" Background="#F5F5F5" >
            <TextBlock Text="Слои" FontWeight="Bold" HorizontalAlignment="Center" Margin="0,5,0,5"/>

            <ListBox x:Name="LayersListBox" Height="200" SelectionChanged="LayersListBox_SelectionChanged">
                <ListBox.ItemTemplate>
                    <DataTemplate>
                        <StackPanel Orientation="Horizontal">
                            <CheckBox IsChecked="{Binding IsVisible}" VerticalAlignment="Center" Click="LayerVisibility_Click"/>
                            <TextBlock Text="{Binding Name}" Margin="5,0" Width="80"/>
                        </StackPanel>
                    </DataTemplate>
                </ListBox.ItemTemplate>
            </ListBox>

            <UniformGrid Columns="2" Margin="0,5">
                <Button Content="+" Click="AddLayer_Click" ToolTip="Добавить слой" Padding="5"/>
                <Button Content="-" Click="RemoveLayer_Click" ToolTip="Удалить слой" Padding="5"/>
                <Button Content="▲" Click="MoveLayerUp_Click" ToolTip="Выше" Padding="5"/>
                <Button Content="▼" Click="MoveLayerDown_Click" ToolTip="Ниже" Padding="5"/>
            </UniformGrid>

            <Button Content="Переместить сюда" Click="MoveShapesToLayer_Click" 
                Margin="0,5" Padding="5" FontSize="10" ToolTip="Переместить выбранные фигуры в выделенный слой"/>
        </StackPanel>

       
        <Canvas x:Name="MainCanvas" 
            Background="White"
            ClipToBounds="True" 
            MouseDown="MainCanvas_MouseDown" 
            MouseMove="MainCanvas_MouseMove" 
            MouseUp="MainCanvas_MouseUp"
            MouseRightButtonDown="MainCanvas_MouseRightButtonDown"
            PreviewMouseLeftButtonDown="ThicknessSlider_PreviewMouseLeftButtonDown"
           />
    </DockPanel>
</Window>
